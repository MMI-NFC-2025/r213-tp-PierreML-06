---
import PbImage from "./PbImage.astro";
import { Image } from "astro:assets";

import favorite from "../assets/icons/favorite.png";
import favoriteFilled from "../assets/icons/favorite_filled.png";

const { offre } = Astro.props;
const { nomMaison, favori = false, prix, surface, adresse, nbChambres, nbSdb } = offre;
---

<article
  class="offre group bg-white rounded-2xl shadow-sm overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-xl w-full"
  data-favori={favori ? "true" : "false"}
>
  <!-- IMAGE -->
  <div class="relative h-52 overflow-hidden bg-slate-200 shrink-0">
    <a href={`/offres/${offre.id}`} class="block h-full">
      <PbImage record={offre} recordImage={offre.images?.[0]} width={500} height={300} />
    </a>

    <!-- Prix -->
    {prix && (
      <span class="absolute top-3 right-3 bg-slate-900/90 backdrop-blur-sm text-white text-xs font-bold px-3 py-1.5 rounded-xl shadow">
        {prix.toLocaleString("fr-FR")} €
      </span>
    )}

    <!-- Badge favori -->
    {favori && (
      <span class="favori-top-badge absolute top-3 left-3 bg-amber-400 text-black text-xs font-bold px-2.5 py-1 rounded-xl shadow">
        Favori
      </span>
    )}

    <!-- Bouton favori -->
    <button
      class="favoriteButton absolute bottom-3 right-3 p-2 bg-white/90 backdrop-blur-sm rounded-full shadow-md hover:scale-110 transition-transform duration-150"
      data-offre={JSON.stringify(offre)}
      data-empty={favorite.src}
      data-filled={favoriteFilled.src}
      type="button"
      aria-label="Ajouter aux favoris"
    >
      <Image class="favorite-icon" src={favori ? favoriteFilled : favorite} alt="Favoris" width={20} height={20} />
    </button>
  </div>

  <!-- CONTENU -->
  <div class="p-5 flex flex-col flex-1">
    <h2 class="font-bold text-slate-900 text-base leading-snug mb-1">
      <a href={`/offres/${offre.id}`} class="hover:text-slate-600 transition-colors">
        {nomMaison}
      </a>
    </h2>

    {adresse && (
      <p class="text-gray-400 text-xs truncate mb-3 flex items-center gap-1.5">
        <svg class="w-3 h-3 shrink-0 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
        </svg>
        <span>{adresse}</span>
      </p>
    )}

    <!-- Stats + lien -->
    <div class="flex items-center gap-2 flex-wrap mt-auto pt-3 border-t border-gray-100">
      {surface && (
        <span class="inline-flex items-center gap-1 text-xs bg-slate-100 text-slate-600 px-2.5 py-1 rounded-lg font-medium">
          {surface} m²
        </span>
      )}
      {nbChambres != null && nbChambres > 0 && (
        <span class="inline-flex items-center gap-1 text-xs bg-slate-100 text-slate-600 px-2.5 py-1 rounded-lg font-medium">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 5.25v13.5m0-7.5h19.5m-19.5 0a4.5 4.5 0 0 1 4.5-4.5h10.5a4.5 4.5 0 0 1 4.5 4.5"/></svg>
          {nbChambres}
        </span>
      )}
      {nbSdb != null && nbSdb > 0 && (
        <span class="inline-flex items-center gap-1 text-xs bg-slate-100 text-slate-600 px-2.5 py-1 rounded-lg font-medium">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v2m0 16v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M2 12h2m16 0h2"/></svg>
          {nbSdb}
        </span>
      )}
      <a href={`/offres/${offre.id}`} class="ml-auto text-xs font-semibold text-slate-600 hover:text-slate-900 transition-colors">
        Voir →
      </a>
    </div>
  </div>
</article>

<script>
  //@ts-nocheck
  import { setFavori } from "../js/backend.mjs";

  const favoriteButtons = document.querySelectorAll(".favoriteButton");

  favoriteButtons.forEach((button) => {
    if (button.dataset.bound === "true") return;
    button.dataset.bound = "true";

    button.addEventListener("click", async () => {
      const offreData = JSON.parse(button.dataset.offre || "{}");
      const newFavori = !offreData.favori;

      await setFavori(offreData);

      const favIcon = button.querySelector(".favorite-icon");
      if (favIcon) {
        favIcon.src = newFavori ? button.dataset.filled : button.dataset.empty;
      }

      const article = button.closest(".offre");
      const topBadge = article?.querySelector(".favori-top-badge");

      if (newFavori) {
        if (!topBadge && article) {
          const imageContainer = article.querySelector(".relative");
          if (imageContainer) {
            const badge = document.createElement("span");
            badge.className = "favori-top-badge absolute top-3 left-3 bg-amber-400 text-black text-xs font-bold px-2.5 py-1 rounded-xl shadow";
            badge.textContent = "Favori";
            imageContainer.appendChild(badge);
          }
        }
      } else {
        topBadge?.remove();
      }

      offreData.favori = newFavori;
      button.dataset.offre = JSON.stringify(offreData);
      if (article) article.dataset.favori = newFavori ? "true" : "false";

      // Notifie le compteur de favoris
      window.dispatchEvent(new CustomEvent("favori-changed"));
    });
  });
</script>
