---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import OffreCard from "../components/OffreCard.astro";
import { getOffres, getAgents } from "../js/backend.mjs";

const offres = await getOffres();
const agents = await getAgents();
const recentOffres = offres.slice(0, 6);
const favCount = offres.filter((o) => o.favori).length;

const faqs = [
  {
    q: "Comment se déroule une estimation gratuite ?",
    a: "Un de nos agents se déplace à votre domicile pour évaluer votre bien. Il analyse l'état du logement, sa localisation, le marché local et vous remet un rapport détaillé sous 48h.",
  },
  {
    q: "Quels sont les frais d'agence ?",
    a: "Nos honoraires sont fixés selon un barème transparent, conforme à la loi Alur. Ils sont calculés en pourcentage du prix de vente et à la charge de l'acheteur sauf mention contraire dans le mandat.",
  },
  {
    q: "Combien de temps faut-il pour vendre un bien ?",
    a: "Le délai moyen de vente sur notre secteur est de 45 à 90 jours selon le type de bien et sa localisation. Une bonne estimation dès le départ est la clé d'une vente rapide.",
  },
  {
    q: "Proposez-vous des services de gestion locative ?",
    a: "Oui. Nous prenons en charge la mise en location, la sélection des locataires, la rédaction des baux, l'encaissement des loyers et la gestion des sinistres.",
  },
  {
    q: "Puis-je confier mon bien à plusieurs agences ?",
    a: "Avec un mandat simple, oui. Avec un mandat exclusif, non — mais l'exclusivité offre un engagement renforcé de notre part et généralement un meilleur résultat final.",
  },
];
---

<Layout titre="Accueil">
  <!-- HERO -->
  <section class="bg-linear-to-br from-slate-900 to-slate-700 text-white pt-20 pb-28 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-slate-400 text-xs font-semibold uppercase tracking-widest mb-5">Agence immobilière — Côte d'Azur</p>
      <h1 class="text-5xl sm:text-6xl font-bold mb-6 leading-tight">
        Trouvez le bien<br />immobilier de vos rêves
      </h1>
      <p class="text-lg text-slate-300 mb-10 max-w-2xl mx-auto leading-relaxed">
        Azuréa Immo vous accompagne dans tous vos projets immobiliers sur la Côte d'Azur.
        Achat, vente, location — nos experts sont à votre service.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/offres" class="rounded-xl px-8 py-4 bg-white text-slate-800 font-semibold hover:bg-slate-100 transition-colors">
          Voir les offres
        </a>
        <a href="/contact" class="rounded-xl px-8 py-4 border border-white/20 text-white font-semibold hover:bg-white/10 transition-colors">
          Nous contacter
        </a>
      </div>
    </div>
  </section>

  <!-- STATS ANIMÉES -->
  <section class="bg-white border-b border-gray-100 py-14 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
      <div>
        <p class="text-4xl font-bold text-slate-900" data-counter data-target={offres.length} data-suffix="+">{offres.length}+</p>
        <p class="text-gray-400 mt-1.5 text-sm">Biens disponibles</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-slate-900" data-counter data-target={agents.length} data-suffix="">{agents.length}</p>
        <p class="text-gray-400 mt-1.5 text-sm">Agents experts</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-slate-900" data-counter data-target="500" data-suffix="+">{favCount > 0 ? favCount : "500"}+</p>
        <p class="text-gray-400 mt-1.5 text-sm">Transactions réalisées</p>
      </div>
      <div>
        <p class="text-4xl font-bold text-slate-900" data-counter data-target="98" data-suffix="%">98%</p>
        <p class="text-gray-400 mt-1.5 text-sm">Clients satisfaits</p>
      </div>
    </div>
  </section>

  <!-- CAROUSEL OFFRES RÉCENTES -->
  {recentOffres.length > 0 && (
    <section class="py-16 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-3xl font-bold text-slate-900">Dernières offres</h2>
            <p class="text-gray-400 text-sm mt-1">{offres.length} bien(s) au total</p>
          </div>
          <div class="flex items-center gap-3">
            <button id="carousel-prev" aria-label="Précédent" class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-slate-600 hover:bg-gray-50 transition-colors disabled:opacity-30">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <button id="carousel-next" aria-label="Suivant" class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-slate-600 hover:bg-gray-50 transition-colors disabled:opacity-30">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>
            <a href="/offres" class="hidden sm:inline text-slate-500 hover:text-slate-800 text-sm font-medium transition-colors">Voir tout →</a>
          </div>
        </div>

        <div id="carousel" class="overflow-x-auto scrollbar-hide flex gap-5 pb-2" style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
          {recentOffres.map((offre) => (
            <div class="min-w-72 sm:min-w-80 shrink-0" style="scroll-snap-align: start;">
              <OffreCard offre={offre} />
            </div>
          ))}
        </div>

        <div class="text-center mt-6 sm:hidden">
          <a href="/offres" class="text-slate-500 hover:text-slate-800 text-sm font-medium transition-colors">Voir toutes les offres →</a>
        </div>
      </div>
    </section>
  )}

  <!-- SERVICES -->
  <section class="bg-slate-50 py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-slate-900">Nos services</h2>
        <p class="text-gray-400 mt-2 text-sm">Un accompagnement complet à chaque étape de votre projet</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <div class="w-11 h-11 bg-slate-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/></svg>
          </div>
          <h3 class="text-base font-semibold mb-2 text-slate-800">Achat &amp; Vente</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Accompagnement complet de A à Z pour l'achat ou la vente de votre bien.</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <div class="w-11 h-11 bg-slate-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z"/></svg>
          </div>
          <h3 class="text-base font-semibold mb-2 text-slate-800">Location</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Gestion locative et mise en location de vos biens immobiliers.</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <div class="w-11 h-11 bg-slate-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Zm3.75 11.625a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
          </div>
          <h3 class="text-base font-semibold mb-2 text-slate-800">Estimation gratuite</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Évaluation précise et gratuite de la valeur de votre bien par nos experts.</p>
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/services" class="inline-flex items-center gap-2 rounded-xl px-7 py-3 bg-slate-800 text-white font-medium hover:bg-slate-700 transition-colors text-sm">
          Découvrir tous nos services
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-slate-900">Questions fréquentes</h2>
        <p class="text-gray-400 mt-2 text-sm">Tout ce que vous devez savoir avant de démarrer votre projet</p>
      </div>
      <div id="faq-list" class="space-y-3">
        {faqs.map((faq, i) => (
          <div class="faq-item bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <button
              class="faq-btn w-full text-left px-6 py-4 flex items-center justify-between gap-4 font-medium text-slate-800 hover:bg-gray-50 transition-colors"
              data-index={i}
            >
              <span>{faq.q}</span>
              <svg class="faq-chevron w-5 h-5 text-gray-400 shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
              </svg>
            </button>
            <div class="faq-body" style="display:none; overflow:hidden;">
              <p class="px-6 pb-5 text-gray-500 text-sm leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-slate-900 text-white py-20 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">Prêt à concrétiser votre projet ?</h2>
      <p class="text-slate-400 mb-10 leading-relaxed">
        Nos agents sont disponibles du lundi au samedi pour vous accompagner, répondre à vos questions et vous guider vers la meilleure décision.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="rounded-xl px-8 py-4 bg-white text-slate-900 font-semibold hover:bg-slate-100 transition-colors">
          Prendre rendez-vous
        </a>
        <a href="/agents" class="rounded-xl px-8 py-4 border border-white/20 text-white font-semibold hover:bg-white/10 transition-colors">
          Rencontrer nos agents
        </a>
      </div>
    </div>
  </section>

  <!-- SCRIPTS -->
  <script>
    // ── Carousel ──────────────────────────────────────────────
    const carousel = document.getElementById("carousel");
    const prevBtn = document.getElementById("carousel-prev");
    const nextBtn = document.getElementById("carousel-next");
    const SCROLL_AMOUNT = 340;

    prevBtn?.addEventListener("click", () => {
      carousel?.scrollBy({ left: -SCROLL_AMOUNT, behavior: "smooth" });
    });
    nextBtn?.addEventListener("click", () => {
      carousel?.scrollBy({ left: SCROLL_AMOUNT, behavior: "smooth" });
    });

    // ── FAQ Accordion ─────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>(".faq-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const item = btn.closest(".faq-item") as HTMLElement;
        const body = item?.querySelector<HTMLElement>(".faq-body");
        const chevron = btn.querySelector<SVGElement>(".faq-chevron");
        const isOpen = body?.style.display !== "none";

        // Ferme tous les autres
        document.querySelectorAll<HTMLElement>(".faq-item").forEach((el) => {
          const b = el.querySelector<HTMLElement>(".faq-body");
          const c = el.querySelector<SVGElement>(".faq-chevron");
          if (b) b.style.display = "none";
          if (c) c.style.transform = "";
        });

        // Ouvre celui cliqué (ou le ferme si déjà ouvert)
        if (!isOpen && body) {
          body.style.display = "block";
          if (chevron) chevron.style.transform = "rotate(180deg)";
        }
      });
    });

    // ── Compteurs animés ──────────────────────────────────────
    const counters = document.querySelectorAll<HTMLElement>("[data-counter]");
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = Number(el.dataset.target ?? 0);
        const suffix = el.dataset.suffix ?? "";
        const duration = 1600;
        const step = target / (duration / 16);
        let current = 0;
        const timer = setInterval(() => {
          current = Math.min(current + step, target);
          el.textContent = Math.floor(current) + suffix;
          if (current >= target) clearInterval(timer);
        }, 16);
        counterObserver.unobserve(el);
      });
    }, { threshold: 0.5 });
    counters.forEach((el) => counterObserver.observe(el));
  </script>
</Layout>
