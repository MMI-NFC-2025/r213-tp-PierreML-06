---
import Layout from "../layouts/Layout.astro";
import { getAgents } from "../js/backend.mjs";

const agents = await getAgents();

const colors = [
  "bg-blue-100 text-blue-700",
  "bg-emerald-100 text-emerald-700",
  "bg-violet-100 text-violet-700",
  "bg-amber-100 text-amber-700",
  "bg-rose-100 text-rose-700",
  "bg-sky-100 text-sky-700",
];
---

<Layout titre="L'Agence">
  <!-- HERO -->
  <section class="bg-linear-to-br from-slate-900 to-slate-700 text-white py-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-slate-400 text-xs font-semibold uppercase tracking-widest mb-4">À propos</p>
      <h1 class="text-4xl font-bold mb-4">Notre agence</h1>
      <p class="text-slate-300 text-lg max-w-2xl mx-auto leading-relaxed">
        Depuis 2010, Azuréa Immo accompagne ses clients dans leurs projets immobiliers sur la Côte d'Azur avec expertise et engagement.
      </p>
    </div>
  </section>

  <!-- NOTRE HISTOIRE -->
  <section class="py-16 px-6 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-bold mb-5 text-slate-900">Notre histoire</h2>
        <p class="text-gray-500 leading-relaxed mb-4">
          Fondée en 2010 à Nice, Azuréa Immo est née de la passion de ses fondateurs pour l'immobilier et de leur conviction que chaque client mérite un accompagnement personnalisé et de qualité.
        </p>
        <p class="text-gray-500 leading-relaxed mb-4">
          En 15 ans, nous avons réalisé plus de 500 transactions immobilières et bâti une réputation solide fondée sur la confiance, la transparence et l'excellence.
        </p>
        <p class="text-gray-500 leading-relaxed">
          Aujourd'hui, notre équipe de {agents.length > 0 ? agents.length : 12} agents experts couvre l'ensemble de la Côte d'Azur pour vous offrir le meilleur de l'immobilier local.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-slate-800 text-white rounded-2xl p-6 text-center">
          <p class="text-4xl font-bold">15</p>
          <p class="text-slate-400 mt-1.5 text-sm">Ans d'expérience</p>
        </div>
        <div class="bg-slate-100 rounded-2xl p-6 text-center">
          <p class="text-4xl font-bold text-slate-800">500+</p>
          <p class="text-gray-500 mt-1.5 text-sm">Transactions</p>
        </div>
        <div class="bg-slate-100 rounded-2xl p-6 text-center">
          <p class="text-4xl font-bold text-slate-800">{agents.length > 0 ? agents.length : 12}</p>
          <p class="text-gray-500 mt-1.5 text-sm">Agents experts</p>
        </div>
        <div class="bg-slate-800 text-white rounded-2xl p-6 text-center">
          <p class="text-4xl font-bold">98%</p>
          <p class="text-slate-400 mt-1.5 text-sm">Clients satisfaits</p>
        </div>
      </div>
    </div>
  </section>

  <!-- NOS VALEURS -->
  <section class="bg-slate-50 py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-10 text-slate-900">Nos valeurs</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <div class="w-11 h-11 bg-slate-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold mb-2 text-slate-800">Confiance</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Une relation transparente et honnête avec chacun de nos clients, fondée sur le respect mutuel.</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <div class="w-11 h-11 bg-slate-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold mb-2 text-slate-800">Excellence</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Un service de qualité supérieure, avec des conseils personnalisés adaptés à chaque situation.</p>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <div class="w-11 h-11 bg-slate-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
            </svg>
          </div>
          <h3 class="text-base font-semibold mb-2 text-slate-800">Innovation</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Des outils modernes et des méthodes innovantes pour simplifier votre parcours immobilier.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ÉQUIPE -->
  {agents.length > 0 && (
    <section class="py-16 px-6 max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-10 text-slate-900">Notre équipe</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {agents.map((agent, i) => {
          const initials = `${(agent.prenom?.[0] ?? "").toUpperCase()}${(agent.nom?.[0] ?? "").toUpperCase()}`;
          const colorClass = colors[i % colors.length];
          return (
            <a href={`/agents/${agent.id}`}
              class="flex items-center gap-4 bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
              <div class={`shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-sm font-bold ${colorClass}`}>
                {initials || "?"}
              </div>
              <div class="min-w-0">
                <h3 class="font-semibold text-slate-800">{agent.prenom} {agent.nom}</h3>
                <p class="text-gray-400 text-xs truncate mt-0.5">{agent.email}</p>
              </div>
            </a>
          );
        })}
      </div>
      <div class="text-center mt-10">
        <a href="/agents" class="inline-flex items-center gap-2 rounded-xl px-7 py-3 bg-slate-800 text-white font-medium hover:bg-slate-700 transition-colors text-sm">
          Voir tous les agents
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-slate-900 text-white py-16 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">Vous souhaitez nous rejoindre ?</h2>
      <p class="text-slate-400 mb-8">Nous recrutons régulièrement des agents passionnés par l'immobilier sur la Côte d'Azur.</p>
      <a href="/contact" class="inline-flex items-center gap-2 rounded-xl px-8 py-4 bg-white text-slate-900 font-semibold hover:bg-slate-100 transition-colors">
        Nous contacter
      </a>
    </div>
  </section>
</Layout>
