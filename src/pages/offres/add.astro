---
import Layout from "../../layouts/Layout.astro";
import { addOffre } from "../../js/backend.mjs";

let message = "";
let success = false;

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const nomMaison = String(formData.get("nomMaison") ?? "").trim();
  const prix = Number(formData.get("prix"));
  const nbSdb = Number(formData.get("nbSdb") || 0);
  const nbChambres = Number(formData.get("nbChambres") || 0);
  const surface = Number(formData.get("surface"));

  const prixOk = Number.isFinite(prix) && prix > 0;
  const surfaceOk = Number.isFinite(surface) && surface > 0;
  const nbSdbOk = Number.isFinite(nbSdb) && nbSdb >= 0;
  const nbChambresOk = Number.isFinite(nbChambres) && nbChambres >= 0;

  if (!nomMaison || !prixOk || !surfaceOk || !nbSdbOk || !nbChambresOk) {
    message = "Veuillez entrer des valeurs valides (nom, prix > 0, surface > 0, nombres ≥ 0).";
  } else {
    const response = await addOffre(formData);
    message = response.message;
    success = response.success;
  }
}
---

<Layout titre="Ajouter une offre">
  <!-- PAGE HEADER -->
  <div class="bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-5 sm:py-6 flex items-center justify-between flex-wrap gap-4">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Ajouter une offre</h1>
        <p class="text-gray-400 text-sm mt-0.5">Renseignez les informations du bien immobilier</p>
      </div>
      <a href="/offres" class="inline-flex items-center gap-2 rounded-xl px-5 py-2.5 border border-gray-200 text-slate-600 text-sm font-medium hover:bg-gray-50 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
        Retour aux offres
      </a>
    </div>
  </div>

  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-6 sm:py-10">

    <!-- MESSAGE -->
    {message && (
      <div class={`mb-6 rounded-2xl p-4 flex items-start gap-3 border ${success ? "bg-emerald-50 border-emerald-200 text-emerald-800" : "bg-red-50 border-red-200 text-red-800"}`}>
        {success ? (
          <svg class="w-5 h-5 shrink-0 mt-0.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
        ) : (
          <svg class="w-5 h-5 shrink-0 mt-0.5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
        )}
        <p class="text-sm font-medium">{message}</p>
      </div>
    )}

    <form action="/offres/add" method="POST" enctype="multipart/form-data"
      class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

      <!-- Informations générales -->
      <div class="px-6 py-5 border-b border-gray-100">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Informations générales</h2>
        <div class="space-y-4">
          <div>
            <label for="nomMaison" class="block text-sm font-medium text-gray-700 mb-1.5">
              Nom du bien <span class="text-red-400">*</span>
            </label>
            <input id="nomMaison" type="text" name="nomMaison" placeholder="Ex : Villa Les Oliviers" required
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-slate-300 bg-gray-50" />
          </div>
          <div>
            <label for="adresse" class="block text-sm font-medium text-gray-700 mb-1.5">Adresse</label>
            <input id="adresse" type="text" name="adresse" placeholder="Ex : 12 Rue du Soleil, 06000 Nice"
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-slate-300 bg-gray-50" />
          </div>
        </div>
      </div>

      <!-- Chiffres clés -->
      <div class="px-6 py-5 border-b border-gray-100">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Chiffres clés</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="prix" class="block text-sm font-medium text-gray-700 mb-1.5">Prix (€) <span class="text-red-400">*</span></label>
            <input id="prix" type="number" name="prix" placeholder="Ex : 350 000" min="1" step="1" required
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-slate-300 bg-gray-50" />
          </div>
          <div>
            <label for="surface" class="block text-sm font-medium text-gray-700 mb-1.5">Surface (m²) <span class="text-red-400">*</span></label>
            <input id="surface" type="number" name="surface" placeholder="Ex : 120" min="1" step="1" required
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-slate-300 bg-gray-50" />
          </div>
          <div>
            <label for="nbChambres" class="block text-sm font-medium text-gray-700 mb-1.5">Chambres</label>
            <input id="nbChambres" type="number" name="nbChambres" placeholder="Ex : 3" min="0" step="1"
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-slate-300 bg-gray-50" />
          </div>
          <div>
            <label for="nbSdb" class="block text-sm font-medium text-gray-700 mb-1.5">Salles de bain</label>
            <input id="nbSdb" type="number" name="nbSdb" placeholder="Ex : 2" min="0" step="1"
              class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-slate-300 bg-gray-50" />
          </div>
        </div>
      </div>

      <!-- Photo -->
      <div class="px-6 py-5 border-b border-gray-100">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Photo</h2>
        <label for="images" class="flex flex-col items-center justify-center gap-3 w-full h-32 border-2 border-dashed border-gray-200 rounded-2xl cursor-pointer hover:border-slate-300 hover:bg-gray-50 transition-colors">
          <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>
          <span class="text-sm text-gray-400">Cliquez pour ajouter une photo</span>
          <span class="text-xs text-gray-300">JPG · PNG · WEBP</span>
        </label>
        <input id="images" type="file" name="images" accept="image/*" class="hidden" />
      </div>

      <!-- Submit -->
      <div class="px-6 py-5 bg-gray-50 flex items-center justify-between gap-4">
        <p class="text-xs text-gray-400">* Champs obligatoires</p>
        <button type="submit" class="inline-flex items-center gap-2 rounded-xl px-6 py-3 bg-slate-800 text-white font-semibold hover:bg-slate-700 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
          Publier l'offre
        </button>
      </div>
    </form>
  </div>
</Layout>
