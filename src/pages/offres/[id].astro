---
import Layout from "../../layouts/Layout.astro";
import { getOffre, getImageUrl } from "../../js/backend.mjs";

const { id } = Astro.params;
const offre = await getOffre(id);

if (!offre) {
    throw new Error("Offre introuvable");
}

const { nomMaison, adresse, surface, prix, favori = false, nbChambres, nbSdb } = offre;
const imageUrl = getImageUrl(offre, offre.images?.[0]);
---

<Layout titre={nomMaison}>
  <!-- BREADCRUMB -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center gap-2 text-sm text-gray-400">
      <a href="/" class="hover:text-slate-700 transition-colors">Accueil</a>
      <span>/</span>
      <a href="/offres" class="hover:text-slate-700 transition-colors">Offres</a>
      <span>/</span>
      <span class="text-slate-700 font-medium truncate">{nomMaison}</span>
    </div>
  </div>

  <!-- IMAGE HERO -->
  {imageUrl ? (
    <div class="w-full h-52 sm:h-80 lg:h-105 overflow-hidden bg-slate-200">
      <img src={imageUrl} alt={nomMaison} class="w-full h-full object-cover" />
    </div>
  ) : (
    <div class="w-full h-48 sm:h-64 bg-slate-200 flex items-center justify-center">
      <svg class="w-16 h-16 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/></svg>
    </div>
  )}

  <!-- CONTENU -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-10 pb-24 lg:pb-10">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">

      <!-- COLONNE PRINCIPALE -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Titre + badges -->
        <div>
          <div class="flex items-start gap-3 flex-wrap mb-2">
            <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">{nomMaison}</h1>
            {favori && (
              <span class="mt-1 bg-amber-400 text-black px-3 py-1 rounded-xl text-xs font-bold">
                ★ Favori
              </span>
            )}
          </div>
          {adresse && (
            <p class="text-gray-400 flex items-center gap-1.5 text-sm">
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
              <span>{adresse}</span>
            </p>
          )}
        </div>

        <!-- Stats visuelles -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          {surface && (
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 text-center">
              <p class="text-3xl font-bold text-slate-800">{surface}</p>
              <p class="text-xs text-gray-400 mt-1">m² habitables</p>
            </div>
          )}
          {nbChambres != null && nbChambres > 0 && (
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 text-center">
              <p class="text-3xl font-bold text-slate-800">{nbChambres}</p>
              <p class="text-xs text-gray-400 mt-1">chambre(s)</p>
            </div>
          )}
          {nbSdb != null && nbSdb > 0 && (
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 text-center">
              <p class="text-3xl font-bold text-slate-800">{nbSdb}</p>
              <p class="text-xs text-gray-400 mt-1">salle(s) de bain</p>
            </div>
          )}
        </div>

        <!-- Fiche détaillée -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
          <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4">
            Détails du bien
          </h2>
          <ul class="divide-y divide-gray-100 text-sm">
            <li class="flex justify-between py-3">
              <span class="text-gray-500">Nom</span>
              <span class="font-medium text-slate-800">{nomMaison}</span>
            </li>
            {adresse && (
              <li class="flex justify-between py-3">
                <span class="text-gray-500">Adresse</span>
                <span class="font-medium text-slate-800 text-right max-w-xs">{adresse}</span>
              </li>
            )}
            {surface && (
              <li class="flex justify-between py-3">
                <span class="text-gray-500">Surface</span>
                <span class="font-medium text-slate-800">{surface} m²</span>
              </li>
            )}
            {nbChambres != null && (
              <li class="flex justify-between py-3">
                <span class="text-gray-500">Chambres</span>
                <span class="font-medium text-slate-800">{nbChambres}</span>
              </li>
            )}
            {nbSdb != null && (
              <li class="flex justify-between py-3">
                <span class="text-gray-500">Salles de bain</span>
                <span class="font-medium text-slate-800">{nbSdb}</span>
              </li>
            )}
            <li class="flex justify-between py-3">
              <span class="text-gray-500">Favori</span>
              <span class="font-medium text-slate-800">{favori ? "Oui ★" : "Non"}</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- SIDEBAR PRIX + CTA -->
      <div class="space-y-4">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 lg:sticky lg:top-24">
          {prix && (
            <div class="mb-6 pb-6 border-b border-gray-100">
              <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Prix</p>
              <p class="text-3xl sm:text-4xl font-bold text-slate-900">
                {prix.toLocaleString("fr-FR")} <span class="text-xl sm:text-2xl font-medium">€</span>
              </p>
            </div>
          )}
          <a
            href="/contact"
            class="flex items-center justify-center gap-2 w-full rounded-xl py-3.5 bg-slate-800 text-white font-semibold hover:bg-slate-700 transition-colors mb-3"
          >
            Contacter un agent
          </a>
          <a
            href="/offres"
            class="flex items-center justify-center gap-2 w-full rounded-xl py-3 border border-gray-200 text-slate-600 text-sm font-medium hover:bg-gray-50 transition-colors"
          >
            ← Retour aux offres
          </a>
        </div>
      </div>
    </div>
  </div>
  <!-- MOBILE STICKY CTA -->
  {prix && (
    <div class="lg:hidden fixed bottom-0 left-0 right-0 z-30 bg-white border-t border-gray-200 px-4 py-3 flex items-center justify-between gap-3 shadow-lg">
      <div>
        <p class="text-xs text-gray-400">Prix</p>
        <p class="text-lg font-bold text-slate-900">{prix.toLocaleString("fr-FR")} €</p>
      </div>
      <a href="/contact" class="flex-1 max-w-xs flex items-center justify-center gap-2 rounded-xl py-3 bg-slate-800 text-white font-semibold text-sm hover:bg-slate-700 transition-colors">
        Contacter un agent
      </a>
    </div>
  )}
</Layout>
