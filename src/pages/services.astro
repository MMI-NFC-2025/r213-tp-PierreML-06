---
import Layout from "../layouts/Layout.astro";
---

<Layout titre="Services">
  <!-- HERO -->
  <section class="bg-linear-to-br from-slate-900 to-slate-700 text-white py-14 sm:py-20 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-slate-400 text-xs font-semibold uppercase tracking-widest mb-4">Ce que nous faisons</p>
      <h1 class="text-3xl sm:text-4xl font-bold mb-4">Nos services</h1>
      <p class="text-slate-300 text-base sm:text-lg max-w-2xl mx-auto leading-relaxed">
        Une gamme complète de services immobiliers pour vous accompagner à chaque étape de votre projet.
      </p>
    </div>
  </section>

  <!-- SERVICES PRINCIPAUX -->
  <section class="py-10 sm:py-16 px-4 sm:px-6 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-8">

      <!-- Achat -->
      <div class="bg-white rounded-2xl shadow-sm p-8 border border-gray-100">
        <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold mb-3 text-slate-800">Achat immobilier</h2>
        <p class="text-gray-400 leading-relaxed mb-5 text-sm">Nos agents vous accompagnent dans la recherche du bien idéal, de la définition de vos critères à la signature de l'acte authentique.</p>
        <ul class="space-y-2.5 text-sm text-gray-500">
          {["Recherche personnalisée", "Visites accompagnées", "Négociation du prix", "Suivi administratif complet"].map(item => (
            <li class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Vente -->
      <div class="bg-white rounded-2xl shadow-sm p-8 border border-gray-100">
        <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold mb-3 text-slate-800">Vente immobilière</h2>
        <p class="text-gray-400 leading-relaxed mb-5 text-sm">Nous optimisons la vente de votre bien grâce à une stratégie marketing ciblée et un réseau d'acheteurs qualifiés.</p>
        <ul class="space-y-2.5 text-sm text-gray-500">
          {["Estimation gratuite", "Photos professionnelles", "Diffusion multi-portails", "Sélection des acheteurs"].map(item => (
            <li class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Location -->
      <div class="bg-white rounded-2xl shadow-sm p-8 border border-gray-100">
        <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold mb-3 text-slate-800">Location &amp; Gestion</h2>
        <p class="text-gray-400 leading-relaxed mb-5 text-sm">Confiez-nous la gestion de votre bien locatif. Nous prenons en charge la mise en location et la gestion quotidienne.</p>
        <ul class="space-y-2.5 text-sm text-gray-500">
          {["Recherche de locataires", "Rédaction des baux", "Encaissement des loyers", "Gestion des travaux"].map(item => (
            <li class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Estimation -->
      <div class="bg-white rounded-2xl shadow-sm p-8 border border-gray-100">
        <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-5">
          <svg class="w-6 h-6 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Zm3.75 11.625a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold mb-3 text-slate-800">Estimation gratuite</h2>
        <p class="text-gray-400 leading-relaxed mb-5 text-sm">Obtenez une évaluation précise et gratuite de votre bien par l'un de nos experts, basée sur le marché local actuel.</p>
        <ul class="space-y-2.5 text-sm text-gray-500">
          {["Analyse du marché local", "Visite de votre bien", "Rapport détaillé", "Conseils personnalisés"].map(item => (
            <li class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- SERVICES COMPLÉMENTAIRES -->
  <section class="bg-slate-50 py-10 sm:py-16 px-4 sm:px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-center mb-8 sm:mb-10 text-slate-900">Services complémentaires</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {[
          {
            title: "Financement",
            desc: "Mise en relation avec des partenaires bancaires",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/>`,
          },
          {
            title: "Conseil juridique",
            desc: "Accompagnement notarial et juridique",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z"/>`,
          },
          {
            title: "Rénovation",
            desc: "Mise en relation avec des artisans de confiance",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z"/>`,
          },
        ].map(({ title, desc, icon }) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 text-center">
            <div class="w-11 h-11 bg-slate-100 rounded-xl flex items-center justify-center mb-4 mx-auto">
              <svg class="w-5 h-5 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icon} />
            </div>
            <h3 class="font-semibold mb-1.5 text-slate-800">{title}</h3>
            <p class="text-gray-400 text-sm">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 sm:py-16 px-4 sm:px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4 text-slate-900">Prêt à démarrer votre projet ?</h2>
      <p class="text-gray-400 mb-8 text-sm leading-relaxed">Contactez-nous pour en savoir plus sur nos services et obtenir un accompagnement personnalisé.</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/contact" class="rounded-xl px-8 py-4 bg-slate-800 text-white font-semibold hover:bg-slate-700 transition-colors">
          Nous contacter
        </a>
        <a href="/offres" class="rounded-xl px-8 py-4 border border-slate-200 text-slate-700 font-semibold hover:bg-slate-50 transition-colors">
          Voir les offres
        </a>
      </div>
    </div>
  </section>
</Layout>
