---
import Layout from "../../layouts/Layout.astro";
import OffreCard from "../../components/OffreCard.astro";
import { getAgents, getOffres } from "../../js/backend.mjs";

const { id } = Astro.params;
const agents = await getAgents();
const agent = agents.find((a) => a.id === id);

const allOffres = await getOffres();
const linkedOffresIds = agent?.offres ?? [];
const offres = allOffres.filter((offre) => linkedOffresIds.includes(offre.id));

const initials = `${(agent?.prenom?.[0] ?? "").toUpperCase()}${(agent?.nom?.[0] ?? "").toUpperCase()}`;
---

<Layout titre={`${agent?.prenom ?? ""} ${agent?.nom ?? ""}`}>
  <!-- BREADCRUMB -->
  <div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center gap-2 text-sm text-gray-400 overflow-hidden">
      <a href="/" class="hover:text-slate-700 transition-colors">Accueil</a>
      <span>/</span>
      <a href="/agents" class="hover:text-slate-700 transition-colors">Agents</a>
      <span>/</span>
      <span class="text-slate-700 font-medium">{agent?.prenom} {agent?.nom}</span>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-10">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 lg:gap-8">

      <!-- SIDEBAR PROFIL -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 text-center lg:sticky lg:top-24">
          <div class="w-20 h-20 rounded-2xl bg-blue-100 text-blue-700 flex items-center justify-center text-xl font-bold mx-auto mb-4">
            {initials || "?"}
          </div>
          <h1 class="font-bold text-slate-900 text-lg leading-tight">{agent?.prenom} {agent?.nom}</h1>
          <p class="text-gray-400 text-xs mt-1">Agent immobilier</p>

          <div class="mt-5 space-y-2 text-left">
            {agent?.email && (
              <div class="flex items-center gap-2.5">
                <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
                <a href={`mailto:${agent.email}`} class="text-xs text-gray-500 hover:text-slate-800 transition-colors truncate">{agent.email}</a>
              </div>
            )}
            {agent?.telephone && (
              <div class="flex items-center gap-2.5">
                <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/></svg>
                <a href={`tel:${agent.telephone}`} class="text-xs text-gray-500 hover:text-slate-800 transition-colors">{agent.telephone}</a>
              </div>
            )}
          </div>

          <div class="mt-5 pt-5 border-t border-gray-100">
            <p class="text-2xl font-bold text-slate-900">{offres.length}</p>
            <p class="text-xs text-gray-400 mt-0.5">bien(s) en portefeuille</p>
          </div>

          <a href="/contact"
            class="mt-5 flex items-center justify-center gap-2 w-full rounded-xl py-2.5 bg-slate-800 text-white text-sm font-medium hover:bg-slate-700 transition-colors">
            Contacter
          </a>
          <a href="/agents"
            class="mt-2 flex items-center justify-center gap-2 w-full rounded-xl py-2.5 border border-gray-200 text-slate-500 text-sm font-medium hover:bg-gray-50 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
            Tous les agents
          </a>
        </div>
      </div>

      <!-- BIENS -->
      <div class="lg:col-span-3">
        <h2 class="text-lg sm:text-xl font-bold text-slate-900 mb-4 sm:mb-6">
          Biens de {agent?.prenom} {agent?.nom}
          <span class="ml-2 text-base font-normal text-gray-400">({offres.length})</span>
        </h2>

        {offres.length > 0 ? (
          <div class="grid gap-4 sm:gap-6 sm:grid-cols-2">
            {offres.map((offre) => <OffreCard offre={offre} />)}
          </div>
        ) : (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center">
            <div class="w-14 h-14 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/></svg>
            </div>
            <p class="text-gray-400 text-sm">Aucun bien lié à cet agent pour le moment.</p>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
