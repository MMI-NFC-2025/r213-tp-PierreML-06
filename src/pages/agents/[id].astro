---
import Layout from "../../layouts/Layout.astro";
import OffreCard from "../../components/OffreCard.astro";
import { getAgents, getOffres } from "../../js/backend.mjs";

const { id } = Astro.params;

// récupérer tous les agents
const agents = await getAgents();

// trouver l'agent courant
const agent = agents.find((a) => a.id === id);

// récupérer toutes les maisons
const allOffres = await getOffres();

// ids des maisons liées à cet agent
const linkedOffresIds = agent?.offres || [];

// filtrer seulement les maisons liées
const offres = allOffres.filter((offre) => linkedOffresIds.includes(offre.id));
---

<Layout title={`Maisons de ${agent?.prenom} ${agent?.nom}`}>
  <section class="max-w-7xl mx-auto px-6 py-12">
    <a href="/agents" class="text-blue-600 hover:underline mb-6 inline-block">
      ← Retour aux agents
    </a>

    <h1 class="text-3xl font-bold mb-2">
      Maisons de {agent?.prenom} {agent?.nom}
    </h1>

    <p class="text-gray-500 mb-10">
      {offres.length} maison(s) liée(s)
    </p>

    {
      offres.length > 0 ? (
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {offres.map((offre) => (
            <OffreCard offre={offre} />
          ))}
        </div>
      ) : (
        <p class="text-gray-500">Aucune maison liée à cet agent.</p>
      )
    }
  </section>
</Layout>